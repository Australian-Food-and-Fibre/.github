# EditorConfig - https://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2
insert_final_newline = false

[*.{ps1,psm1,psd1}]
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 120

[*.sql]
indent_size = 4

[Makefile]
indent_style = tab
